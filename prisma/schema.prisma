generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Docente {
  id               Int              @id @default(autoincrement())
  rfid             String           @unique
  nombre           String
  iniciales        String
  prestamosActivos Int              @default(0)
  carreras         DocenteCarrera[]
  registros        Registro[]
  prestamos        Prestamo[]
  createdAt        DateTime         @default(now())
}

model Carrera {
  id       Int              @id @default(autoincrement())
  nombre   String           @unique
  docentes DocenteCarrera[]
  ciclos   Ciclo[]
}

model DocenteCarrera {
  id        Int     @id @default(autoincrement())
  docente   Docente @relation(fields: [docenteId], references: [id])
  docenteId Int
  carrera   Carrera @relation(fields: [carreraId], references: [id])
  carreraId Int
}

model Ciclo {
  id        Int       @id @default(autoincrement())
  numero    Int
  carrera   Carrera   @relation(fields: [carreraId], references: [id])
  carreraId Int
  materias  Materia[]
}

model Materia {
  id      Int    @id @default(autoincrement())
  nombre  String
  ciclo   Ciclo  @relation(fields: [cicloId], references: [id])
  cicloId Int
}

model Libro {
  id              Int        @id @default(autoincrement())
  codigo          String     @unique
  titulo          String
  autor           String
  anio            Int
  categoria       String
  totalEjemplares Int        @default(1)
  disponibles     Int        @default(1)
  descripcion     String

  // ── Metadatos ricos del inventario institucional ──
  tipo            String     @default("LIBRO") // "LIBRO" | "REVISTA"
  isbn            String?
  codigoDewey     String?
  codigoCutter    String?
  edicion         String?
  paginas         Int?
  editorial       String?
  idioma          String?
  soloEnSala      Boolean    @default(false)
  programa        String?    // carrera de origen según el inventario (puede diferir de "categoria")
  palabrasClave   String?
  citaBibliografica String?

  prestamos       Prestamo[]
  createdAt       DateTime   @default(now())
}

model Prestamo {
  id              Int       @id @default(autoincrement())
  docente         Docente   @relation(fields: [docenteId], references: [id])
  docenteId       Int
  libro           Libro     @relation(fields: [libroId], references: [id])
  libroId         Int
  fechaPrestamo   DateTime  @default(now())
  fechaDevolucion DateTime?
  activo          Boolean   @default(true)
}

model Registro {
  id        Int      @id @default(autoincrement())
  tipo      String
  docente   Docente  @relation(fields: [docenteId], references: [id])
  docenteId Int
  actividad String?
  detalle   String?
  carrera   String?
  ciclo     Int?
  materia   String?
  jornada   String?
  libroId   Int?
  fecha     DateTime @default(now())
}

model RfidScan {
  id        Int      @id @default(autoincrement())
  uid       String
  leido     Boolean  @default(false)
  createdAt DateTime @default(now())
}