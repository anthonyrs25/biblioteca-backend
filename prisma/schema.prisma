generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Usuario {
  id               Int              @id @default(autoincrement())
  nombre           String
  email            String?          @unique
  password         String?
  rfid             String?          @unique
  rol              String           @default("usuario") // "usuario" | "bibliotecario" | "admin"
  tipoPersona      String           @default("DOCENTE")  // "DOCENTE" | "ESTUDIANTE" | "INVITADO"
  iniciales        String?
  prestamosActivos Int              @default(0)
  carreras         UsuarioCarrera[]
  registros        Registro[]
  prestamos        Prestamo[]
  createdAt        DateTime         @default(now())
}

model Carrera {
  id       Int              @id @default(autoincrement())
  nombre   String           @unique
  usuarios UsuarioCarrera[]
  ciclos   Ciclo[]
}

model UsuarioCarrera {
  id        Int     @id @default(autoincrement())
  usuario   Usuario @relation(fields: [usuarioId], references: [id])
  usuarioId Int
  carrera   Carrera @relation(fields: [carreraId], references: [id])
  carreraId Int
}

model Ciclo {
  id        Int       @id @default(autoincrement())
  numero    Int
  carrera   Carrera   @relation(fields: [carreraId], references: [id])
  carreraId Int
  materias  Materia[]
}

model Materia {
  id      Int    @id @default(autoincrement())
  nombre  String
  ciclo   Ciclo  @relation(fields: [cicloId], references: [id])
  cicloId Int
}

model Libro {
  id                Int        @id @default(autoincrement())
  codigo            String     @unique
  titulo            String
  autor             String
  anio              Int
  categoria         String
  totalEjemplares   Int        @default(1)
  disponibles       Int        @default(1)
  descripcion       String
  tipo              String     @default("LIBRO")
  isbn              String?
  codigoDewey       String?
  codigoCutter      String?
  edicion           String?
  paginas           Int?
  editorial         String?
  idioma            String?
  soloEnSala        Boolean    @default(false)
  programa          String?
  palabrasClave     String?
  citaBibliografica String?
  prestamos         Prestamo[]
  createdAt         DateTime   @default(now())
}

model Prestamo {
  id              Int       @id @default(autoincrement())
  usuario         Usuario   @relation(fields: [usuarioId], references: [id])
  usuarioId       Int
  libro           Libro     @relation(fields: [libroId], references: [id])
  libroId         Int
  fechaPrestamo   DateTime  @default(now())
  fechaDevolucion DateTime?
  activo          Boolean   @default(true)
  nombreInvitado  String?
  tipoDocumento   String?
  numeroDocumento String?
}

model Registro {
  id        Int      @id @default(autoincrement())
  tipo      String
  usuario   Usuario  @relation(fields: [usuarioId], references: [id])
  usuarioId Int
  actividad String?
  detalle   String?
  carrera   String?
  ciclo     Int?
  materia   String?
  jornada   String?
  libroId   Int?
  fecha     DateTime @default(now())
}

model RfidScan {
  id        Int      @id @default(autoincrement())
  uid       String
  leido     Boolean  @default(false)
  createdAt DateTime @default(now())
}